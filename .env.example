# © Author: aliyie
# https://discord.gg/aerox

# --- Server -----------------------------------------------------------------
# Port the API listens on. Defaults to 8080 if unset.
# Hosted platforms (Render, Railway, Fly, Heroku, etc.) set this for you.
PORT=8080

# Set to "production" in any deployed environment for structured JSON logs.
NODE_ENV=development

# Pino log level. One of: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Auth -------------------------------------------------------------------
# If set, every request must include `x-api-key: <value>` or it returns 401.
# Leave unset for open access. Set this before exposing the URL publicly.
API_KEY=

# --- CORS -------------------------------------------------------------------
# Comma-separated list of origins allowed to call this API from browser JS,
# e.g. https://myapp.com,https://admin.myapp.com. Leave unset to disallow all
# browser-based cross-origin calls (Discord bots and other server-side
# callers are unaffected — CORS only applies to browsers).
ALLOWED_ORIGINS=

# --- Rate limiting / concurrency --------------------------------------------
# Requests per client IP per window, applied to the whole /api namespace.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Stricter limit specifically on /media/download (spawns ffmpeg, can run
# for minutes).
DOWNLOAD_RATE_LIMIT_MAX=10
DOWNLOAD_RATE_LIMIT_WINDOW_MS=600000

# Max number of yt-dlp/ffmpeg subprocesses allowed to run at once. Keep in
# step with the CPU/RAM of whatever plan/instance you're on.
DLP_MAX_CONCURRENT_INFO=8
DLP_MAX_CONCURRENT_DOWNLOADS=2

# When the concurrency cap above is hit, the default is an immediate 429.
# Set to "true" to instead queue the request and wait for a free slot.
QUEUE_ENABLED=false
QUEUE_MAX_WAIT_MS=15000
QUEUE_MAX_LENGTH=50

# Reject downloads above this size before they hit disk. yt-dlp size syntax
# (e.g. 500M, 2G). Leave unset for no limit.
# YTDLP_MAX_FILESIZE=500M

# How often (ms) to sweep and delete leftover temp download dirs from
# crashed/killed requests.
# TEMP_SWEEP_INTERVAL_MS=1800000

# --- Redis (optional) --------------------------------------------------------
# Enables three things at once when set: a shared/persistent rate-limit
# store, a shared metadata cache, and shared per-IP quota counters. Without
# it, all three fall back to in-memory equivalents scoped to this process —
# fine for a single instance, but state resets on restart and isn't shared
# across multiple instances.
# REDIS_URL=redis://localhost:6379

# --- Metadata cache -----------------------------------------------------------
# How long /media/info and /media/direct-url responses are cached for. CDN
# URLs from direct-url usually carry short-lived expiry tokens, hence the
# shorter default there.
CACHE_TTL_INFO_MS=300000
CACHE_TTL_DIRECT_URL_MS=120000

# Max entries held by the in-memory cache fallback (ignored when REDIS_URL
# is set — Redis has no such cap here).
CACHE_MAX_ITEMS=500

# --- Per-IP quotas (opt-in) ---------------------------------------------------
# A longer-window ceiling per IP, separate from the short-window rate limit
# above — e.g. "50 downloads per day" rather than "10 per 10 minutes".
QUOTA_ENABLED=false
QUOTA_WINDOW_MS=86400000
QUOTA_MAX_INFO=500
QUOTA_MAX_DIRECT_URL=500
QUOTA_MAX_DOWNLOADS=50

# --- Metrics ------------------------------------------------------------------
# Prometheus metrics are served at GET /metrics. If set, scraping requires
# `x-metrics-key: <value>`; left unset, /metrics is open (typical when only
# scraped over a private network).
METRICS_KEY=

# --- yt-dlp -----------------------------------------------------------------
# Path to the yt-dlp binary. The Dockerfile installs it at this path inside
# a Python venv. Override only if you know what you're doing.
# YTDLP_BIN=/opt/ytdlp-venv/bin/yt-dlp

# Path to a Netscape-format cookies.txt. Required for YouTube and other
# sites that block unauthenticated traffic from cloud IPs.
# Get cookies from your browser via the "Get cookies.txt LOCALLY" extension.
# On startup this is copied to a writable location so yt-dlp can refresh the
# jar even if the source path is mounted read-only (e.g. Render Secret
# Files), then re-synced on an interval if you replace the source file.
# YTDLP_COOKIES_FILE=/secrets/cookies.txt

# How often (ms) to check the source cookies file for changes and re-sync.
# COOKIE_SYNC_INTERVAL_MS=300000

# How far ahead (ms) to warn about cookies nearing expiry.
# COOKIE_EXPIRY_WARNING_MS=86400000

# Max time (ms) a download is allowed to run before being force-killed.
# Default is 10 minutes (600000 ms). Bump this for very long videos.
# YTDLP_DOWNLOAD_TIMEOUT_MS=600000
