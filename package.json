{
  "name": "dlp-wrapper",
  "version": "1.1.0",
  "description": "A self-hosted REST API wrapping yt-dlp for fetching metadata, resolving direct CDN URLs, and downloading media (MP4/MP3) from 1,750+ sites. Drop-in for use in web apps and Discord bots.",
  "type": "module",
  "main": "src/index.mjs",
  "scripts": {
    "start": "node --enable-source-maps src/index.mjs",
    "dev": "node --watch --enable-source-maps src/index.mjs",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "yt-dlp",
    "youtube-dl",
    "media",
    "download",
    "mp3",
    "mp4",
    "discord",
    "api"
  ],
  "license": "MIT",
  "author": "aliyie",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.2",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.1.0"
  }
}
